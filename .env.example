# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# API 配置
API_BASE=api_base_url_here
API_KEY=api_key_here

# 阿里云 OSS 配置
OSS_ACCESS_KEY_ID="your access key id here"
OSS_ACCESS_KEY_SECRET="your access key secret here"
OSS_ENDPOINT="your oss endpoint here"
OSS_BUCKET_NAME="your oss bucket name here"

# Flask 配置
FLASK_PORT=5000
FLASK_DEBUG=True
